# ===========================================
# MONGODB
# ===========================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# ===========================================
# JWT
# ===========================================
JWT_SECRET=your_jwt_secret_key_here

# ===========================================
# CLOUDINARY (for image uploads)
# ===========================================
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET_KEY=your_cloudinary_secret_key
CLOUDINARY_NAME=your_cloudinary_name

# ===========================================
# ADMIN
# ===========================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin_password_here

# ===========================================
# STRIPE (payment gateway)
# ===========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ===========================================
# RAZORPAY (payment gateway - optional)
# ===========================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ===========================================
# FRONTEND URL (for OAuth callbacks)
# ===========================================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ===========================================
# GOOGLE OAUTH
# Get credentials from: https://console.developers.google.com/
# 1. Create a new project
# 2. Go to Credentials > Create Credentials > OAuth 2.0 Client IDs
# 3. Add authorized redirect URI: http://localhost:5000/api/auth/google/callback
# ===========================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# GITHUB OAUTH
# Get credentials from: https://github.com/settings/developers
# 1. Go to Settings > Developer Settings > OAuth Apps > New OAuth App
# 2. Set Homepage URL: http://localhost:5173
# 3. Set Authorization callback URL: http://localhost:5000/api/auth/github/callback
# ===========================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ===========================================
# FACEBOOK OAUTH
# Get credentials from: https://developers.facebook.com/
# 1. Create a new app at developers.facebook.com
# 2. Add Facebook Login product
# 3. Set Valid OAuth Redirect URIs: http://localhost:5000/api/auth/facebook/callback
# ===========================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ===========================================
# EMAIL OTP (using nodemailer)
# For Gmail, use App Password: https://myaccount.google.com/apppasswords
# ===========================================
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ===========================================
# NODE ENVIRONMENT
# ===========================================
NODE_ENV=development
